# mads-cli configuration
# Copy to .env and fill in your values. Never commit .env.

# ── Required ─────────────────────────────────────────────────
META_APP_ID=                         # Meta App ID (developers.facebook.com)
META_APP_SECRET=                     # Meta App Secret — required for appsecret_proof on EVERY call
META_AD_ACCOUNT_ID=                  # e.g. act_1234567890

# ── Business Manager (required for system-user/business commands) ──
META_BUSINESS_ID=                    # Business Manager ID

# ── Paths (defaults work if repo layout is standard) ─────────
# MADS_PROJECT_ROOT=                 # Parent project root (auto-detected)
# MADS_DB_PATH=                      # SQLite database path (default: <scope>/data/mads.db)
# MADS_CREDENTIALS_PATH=             # OAuth token JSON path (default: <scope>/credentials/meta-oauth.json)
# MADS_SNAPSHOTS_DIR=                # Snapshot output directory (default: <scope>/snapshots)

# ── Preferences ──────────────────────────────────────────────
# META_API_VERSION=v25.0             # Meta Marketing/Graph API version
# MADS_TIMEZONE=UTC                  # IANA timezone (e.g. America/New_York, Asia/Dubai)
# MADS_CURRENCY=USD                  # ISO 4217 currency code (e.g. USD, AED, EUR, GBP)
